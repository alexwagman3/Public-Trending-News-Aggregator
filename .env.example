# Required: DeepSeek API key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: blend between trending engagement (1.0) and recency (0.0).
# Default 0.5 favors sustained weekly stories without ignoring fresh news.
TRENDING_BIAS=0.50

# Optional: directory the briefing is written to (relative or absolute).
OUTPUT_DIR=output
